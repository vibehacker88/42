var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.sendPageSize=function(t){ovkvmf.registredFrames[t].adFrame||document.getElementById(t)&&(ovkvmf.registredFrames[t].adFrame=document.getElementById(t).contentWindow),ASCDP.adS.loadModules(["getWinWidth","getWinHeight"],function(){try{ovkvmf.registredFrames[t].adFrame&&ovkvmf.registredFrames[t].adFrame.postMessage("pageSize:;:"+ASCDP.adS.getWinWidth()+"x"+ASCDP.adS.getWinHeight()+":;:"+t,"*")}catch(e){ovkvmf.registredFrames[t].adFrame&&ovkvmf.registredFrames[t].adFrame.postMessage("pageSize:;:"+ASCDP.adS.getWinWidth()+"x"+ASCDP.adS.getWinHeight()+":;:"+t,"*")}})};