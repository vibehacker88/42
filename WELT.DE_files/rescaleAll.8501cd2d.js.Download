var ASCDP=window.ASCDP||{};ASCDP.adS=ASCDP.adS||{},ASCDP.adS.rescaleAll=function(){let a=ASCDP.adS;a.loadModules(["backchanger","getNavHeight","getBarHeight","calcX"],function(){a.resizeArr=a.resizeArr.filter(function(e,r){return a.resizeArr.indexOf(e)===r&&!/^\d*$/.test(e)}),a.resizeArr.forEach(e=>{a.adElts[e]?.rescale&&a.adElts[e].rescale()}),a.backchanger(),ovkvmf.propagateWinResize()})};