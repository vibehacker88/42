var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.sendPageSet=function(a){var r={message:"pageSet",data:ASCDP.pageSet};ovkvmf.registredFrames[a].adFrame||document.getElementById(a)&&(ovkvmf.registredFrames[a].adFrame=document.getElementById(a).contentWindow);try{ovkvmf.registredFrames[a].adFrame&&ovkvmf.registredFrames[a].adFrame.postMessage(JSON.parse(JSON.stringify(r)),"*")}catch(e){ovkvmf.registredFrames[a].adFrame&&ovkvmf.registredFrames[a].adFrame.postMessage(JSON.parse(JSON.stringify(r)),"*")}};