ASCDP.partners.id5={init:()=>{let t=ASCDP.adS,a=ASCDP.pageSet;if(!ASCDP.partners?.id5?.data&&ASCDP.tcf.storageAccess&&a.storageAccess)try{var e=localStorage.getItem("id5id");e&&(ASCDP.partners.id5.data=e)}catch(t){console.warn("ID5 cache access blocked:",t)}t.loadScripts(["https://cdn.id5-sync.com/api/1.0/id5-api.js"],()=>{let t;t=ASCDP.tcf.data?{partnerId:a.partnerScripts.id5.id||1831,cmpApi:"static",consentData:{getTCData:ASCDP.tcf.data}}:{partnerId:a.partnerScripts.id5.id||1831},window.ID5.init(t).onUpdate(t=>{ASCDP.partners.id5.data=t.getUserId()})})}};