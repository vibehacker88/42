var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.sendClickThrough=e=>{var r=e.replace(/_frame\d+/,""),r=ASCDP.adS.adElts[r],a=document.getElementById(e);if(a){ovkvmf.registredFrames[e].adFrame||(ovkvmf.registredFrames[e].adFrame=a.contentWindow);try{ovkvmf.registredFrames[e].adFrame&&ovkvmf.registredFrames[e].adFrame.postMessage({clickThrough:r.clickThrough},"*")}catch{ovkvmf.registredFrames[e].adFrame&&ovkvmf.registredFrames[e].adFrame.postMessage({clickThrough:r.clickThrough},"*")}}};