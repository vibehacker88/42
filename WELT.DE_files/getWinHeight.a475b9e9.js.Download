var ASCDP=window.ASCDP||{};ASCDP.adS=ASCDP.adS||{},ASCDP.adS.getWinHeight=function(){let t;if(ASCDP.pageSet.isMobile){let e=NaN;var i=document.querySelector("meta[name=viewport]");i&&(i=i.getAttribute("content").match(/width=([0-9]+)/i))&&(e=parseInt(i[1])),t=isNaN(e)?Math.min(window.innerHeight,window.outerHeight):e/window.screen.width*Math.min(window.innerHeight,window.outerHeight)}else t=document.documentElement?.clientHeight||document.body?.clientHeight||window.innerHeight;return t};