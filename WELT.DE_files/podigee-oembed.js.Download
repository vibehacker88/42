      };
    }();

    // eslint-disable-next-line no-unused-vars
    var PodigeeSingleEpisodePodcastPlayer = function () {
        function PodigeeSingleEpisodePodcastPlayer(options) {
            classCallCheck(this, PodigeeSingleEpisodePodcastPlayer);

            this.options = options;
