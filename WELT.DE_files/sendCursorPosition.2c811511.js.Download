var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.sendCursorPosition=function(r,a){a={message:"cursorPosition",data:{X:a.pageX,Y:a.pageY}};ovkvmf.registredFrames[r].adFrame||document.getElementById(r)&&(ovkvmf.registredFrames[r].adFrame=document.getElementById(r).contentWindow);try{ovkvmf.registredFrames[r].adFrame&&ovkvmf.registredFrames[r].adFrame.postMessage(JSON.parse(JSON.stringify(a)),"*")}catch(e){ovkvmf.registredFrames[r].adFrame&&ovkvmf.registredFrames[r].adFrame.postMessage(JSON.parse(JSON.stringify(a)),"*")}};