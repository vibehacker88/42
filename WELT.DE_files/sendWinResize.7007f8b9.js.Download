var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.sendWinResize=function(e){var r=document.getElementById(e);if(!ovkvmf.registredFrames[e].adFrame){if(!r)return;ovkvmf.registredFrames[e].adFrame=r.contentWindow}r=getComputedStyle(r||ovkvmf.registredFrames[e].adFrame);ovkvmf.registredFrames[e].adFrame.postMessage("windowSize:;:"+r.width+"x"+r.height+":;:"+e,"*")};