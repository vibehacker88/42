var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.sendWinScroll=function(r){ovkvmf.registredFrames[r].adFrame||document.getElementById(r)&&(ovkvmf.registredFrames[r].adFrame=document.getElementById(r).contentWindow),ovkvmf.registredFrames[r].adFrame||(ovkvmf.registredFrames[r].adFrame=document.getElementById(r)),ASCDP.adS.loadModules(["getScrollTop"],function(){try{ovkvmf.registredFrames[r].adFrame&&ovkvmf.registredFrames[r].adFrame.postMessage("windowScroll:;:"+ASCDP.adS.getScrollTop()+":;:"+r,"*")}catch(e){ovkvmf.registredFrames[r].adFrame&&ovkvmf.registredFrames[r].adFrame.postMessage("windowScroll:;:"+ASCDP.adS.getScrollTop()+":;:"+r,"*")}})};