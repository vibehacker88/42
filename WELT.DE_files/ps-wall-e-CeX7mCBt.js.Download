td.svelte-io32eg {vertical-align:top;}.status-text.svelte-io32eg {margin:0;}.articles-table.svelte-io32eg {width:100%;border-collapse:collapse;}.article-title.svelte-io32eg {word-break:break-word;}.clamp-lines.svelte-io32eg {display:-webkit-box;-webkit-box-orient:vertical;overflow:hidden;-webkit-line-clamp:4;line-clamp:4;}
@media (min-width: 450px) {.clamp-lines.svelte-io32eg {-webkit-line-clamp:2;line-clamp:2;}
}

/* BILD */.container--bild.svelte-io32eg {font-family:ps-bild-gotham-xnarrow, sans-serif;font-size:17px;font-weight:325;color:#212529;background:rgb(248, 249, 250);padding:24px;border-radius:8px;box-shadow:0 2px 8px 0px rgba(0, 0, 0, 0.3);}.container--bild.svelte-io32eg .heading:where(.svelte-io32eg) {font-family:ps-bild-gotham, sans-serif;font-weight:450;font-size:20px;line-height:1;margin:0;}.container--bild.svelte-io32eg .credits-note:where(.svelte-io32eg) {margin:24px 0;}.container--bild.svelte-io32eg .credits-amount:where(.svelte-io32eg) {font-weight:400;}.container--bild.svelte-io32eg th:where(.svelte-io32eg),
.container--bild.svelte-io32eg td:where(.svelte-io32eg) {padding:0 36px 24px 0;}.container--bild.svelte-io32eg tr:where(.svelte-io32eg):last-child td:where(.svelte-io32eg) {padding-bottom:0;}.container--bild.svelte-io32eg th:where(.svelte-io32eg):last-child,
.container--bild.svelte-io32eg td:where(.svelte-io32eg):last-child {padding-right:0;}.container--bild.svelte-io32eg .table-heading:where(.svelte-io32eg) {text-align:left;font-size:20px;line-height:21px;font-weight:400;}.container--bild.svelte-io32eg .article-title:where(.svelte-io32eg) {font-size:16px;line-height:21px;}.container--bild.svelte-io32eg .article-link:where(.svelte-io32eg) {color:#212529;font-weight:400;text-decoration:underline;}

