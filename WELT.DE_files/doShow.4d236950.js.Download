var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.doShow=function(m){if(document.getElementById(m)){document.getElementById(m).style.display="block",ovkvmf.registredFrames[m].adFrame||document.getElementById(m)&&(ovkvmf.registredFrames[m].adFrame=document.getElementById(m).contentWindow);try{ovkvmf.registredFrames[m].adFrame&&ovkvmf.registredFrames[m].adFrame.postMessage("showAd:;:"+m,"*")}catch(e){ovkvmf.registredFrames[m].adFrame&&ovkvmf.registredFrames[m].adFrame.postMessage("showAd:;:"+m,"*")}}};