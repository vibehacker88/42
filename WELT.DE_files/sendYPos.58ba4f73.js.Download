var ASCDP=window.ASCDP||{};ASCDP.ovkvmf=ASCDP.ovkvmf||{},ASCDP.ovkvmf.sendYPos=function(r){var m=document.getElementById(r);if(m){m=ASCDP.adS.calcY(m,m.offsetTop);ovkvmf.registredFrames[r].adFrame||document.getElementById(r)&&(ovkvmf.registredFrames[r].adFrame=document.getElementById(r).contentWindow);try{ovkvmf.registredFrames[r].adFrame&&ovkvmf.registredFrames[r].adFrame.postMessage("responseY="+m,"*")}catch(e){ovkvmf.registredFrames[r].adFrame&&ovkvmf.registredFrames[r].adFrame.postMessage("responseY="+m,"*")}}};